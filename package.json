{
  "name": "lobster-farmer-cli",
  "version": "0.1.0",
  "private": false,
  "description": "Lobster Farmer CLI for OpenClaw auto-feeding and lobster growth simulation",
  "license": "MIT",
  "type": "module",
  "bin": {
    "lobster-farmer": "./bin/lobster-farmer.cjs"
  },
  "files": [
    "bin",
    "dist",
    "public",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "dev": "tsx watch server/index.ts",
    "start": "node ./bin/lobster-farmer.cjs start",
    "start:fg": "npm run build && node dist/index.js",
    "stop": "node ./bin/lobster-farmer.cjs stop",
    "status": "node ./bin/lobster-farmer.cjs status",
    "prepack": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.2",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
